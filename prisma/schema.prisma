generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id    String  @id @default(uuid())
  phone String  @unique
  name  String?
  age   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
